            connections["zonecast"]:Disconnect()
        end)
    end
end)

autoBestiary_t:OnChanged(function(Value)
    if Value then
        zoneCast_t:SetValue(true)
        for i, v in mod do
            if autoBestiary_t.Value == false then
                break
            end
            if typeof(v) == "table" and v.Rarity and not autoBestiary_d.Value[v.Rarity] then
                continue
            end
            if best:FindFirstChild(i) then
                continue
            end
            print(`Need Fish : {i}`)
            local imppossible = true
            for a, b in zonesMod do
                if table.find(b.Pool, i) then
                    print(`You Will Find It In {a}`)
                    imppossible = false
                    zoneCast_d:SetValue(a)
                    break
                end
            end
            if imppossible then warn("skipped caus impossible"); continue end
            repeat task.wait(1) until best:FindFirstChild(i)
        end
    end
end)

